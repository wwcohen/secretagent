│ - September: 30 days                                                                                                 │
│ - October: 31 days                                                                                                   │
│ - November: 30 days                                                                                                  │
│ - December: 31 days                                                                                                  │
│ Total days from July 18 to Dec 31, 2013 = 13 + 31 + 30 + 31 + 30 + 31 = 166 days                                     │
│                                                                                                                      │
